.supplier-invoices-container {
  padding: 24px;
  max-width: 1400px;
  margin: 0 auto;
}

.page-header {
  margin-bottom: 24px;

  h1 {
    margin: 0 0 8px 0;
    font-size: 28px;
    font-weight: 500;
    color: #333;
  }

  .subtitle {
    margin: 0;
    color: #666;
    font-size: 14px;
  }
}

// Upload Card
.upload-card {
  margin-bottom: 24px;
  
  .dropzone {
    border: 2px dashed #ccc;
    border-radius: 8px;
    padding: 48px 24px;
    text-align: center;
    transition: all 0.3s ease;
    background: #fafafa;
    cursor: pointer;

    &.drag-over {
      border-color: #667eea;
      background: #f0f4ff;
      
      .upload-icon {
        color: #667eea;
        transform: scale(1.1);
      }
    }

    &.uploading {
      border-color: #667eea;
      background: #f0f4ff;
      cursor: default;
    }

    .upload-icon {
      font-size: 64px;
      width: 64px;
      height: 64px;
      color: #999;
      margin-bottom: 16px;
      transition: all 0.3s ease;
    }

    .upload-text {
      .primary-text {
        font-size: 18px;
        font-weight: 500;
        color: #333;
        margin: 0 0 8px 0;
      }

      .secondary-text {
        font-size: 14px;
        color: #666;
        margin: 0 0 16px 0;
      }

      button {
        margin: 16px 0;
      }

      .hint-text {
        font-size: 12px;
        color: #999;
        margin: 16px 0 0 0;
        line-height: 1.6;
      }
    }

    .upload-progress {
      mat-spinner {
        margin: 0 auto 16px;
      }

      p {
        margin: 8px 0;
        color: #666;
      }

      mat-progress-bar {
        margin: 16px auto;
        max-width: 400px;
      }

      .progress-text {
        font-weight: 500;
        color: #667eea;
      }
    }
  }
}

// Documents Card
.documents-card {
  .loading-state, .empty-state {
    text-align: center;
    padding: 48px 24px;
    color: #666;

    mat-spinner {
      margin: 0 auto 16px;
    }

    .empty-icon {
      font-size: 64px;
      width: 64px;
      height: 64px;
      margin: 0 auto 16px;
    }

    h3 {
      margin: 0 0 8px 0;
      color: #333;
    }

    p {
      margin: 0;
      color: #666;
    }
  }

  .documents-table-container {
    overflow-x: auto;
    
    .documents-table {
      width: 100%;

      .icon-cell {
        width: 48px;
        
        .file-icon {
          font-size: 24px;
        }
      }

      .filename-cell {
        max-width: 300px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;

        strong {
          color: #333;
        }
      }

      .file-type-badge {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        background: #e3f2fd;
        color: #1976d2;
      }

      .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;

        &.status-active {
          background: #e8f5e9;
          color: #2e7d32;
        }

        &.status-inactive {
          background: #ffebee;
          color: #c62828;
        }
      }

      .actions-cell {
        white-space: nowrap;
        
        button {
          margin: 0 4px;
        }
      }

      .document-row {
        transition: background-color 0.2s ease;

        &:hover {
          background-color: #f5f5f5;
        }
      }
    }
  }
}

// Responsive
@media (max-width: 768px) {
  .supplier-invoices-container {
    padding: 16px;
  }

  .upload-card .dropzone {
    padding: 32px 16px;

    .upload-icon {
      font-size: 48px;
      width: 48px;
      height: 48px;
    }
  }

  .documents-table {
    font-size: 14px;

    th, td {
      padding: 8px 4px;
    }
  }
}
