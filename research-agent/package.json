{
  "name": "markt-ma-research-agent",
  "version": "1.0.0",
  "description": "Legaler Marketplace-Research-Agent für Marokko – sammelt öffentliche Händlerprofile und bewertet Leads für markt.ma",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start":       "node main.js",
    "demo":        "node main.js --demo",
    "demo:debug":  "node main.js --demo --debug-scoring",

    "avito":       "node main.js --source avito",
    "opensooq":    "node main.js --source opensooq",
    "jumia":       "node main.js --source jumia",
    "all":         "node main.js --source all",

    "hot-leads":   "node main.js --hot-only --source avito",
    "hot-leads:all":"node main.js --hot-only --source all",
    "saas-fit":    "node main.js --min-saas 70 --source avito",
    "import-ready":"node main.js --hot-only --min-saas 45 --source avito"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "csv-writer": "^1.6.0",
    "robots-parser": "^3.0.1",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "minimist": "^1.2.8",
    "p-limit": "^3.1.0",
    "user-agents": "^1.1.238"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": ["marokko", "leads", "scraping", "marketplace", "avito", "opensooq"],
  "license": "MIT"
}

