# ==========================================
# Store Backend Environment Variables
# Kopiere diese Datei nach /etc/storebackend.env auf dem VPS
# ==========================================

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/storedb
SPRING_DATASOURCE_USERNAME=storeapp
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_SECRET=change-me-in-production-to-a-very-long-secret-key-at-least-256-bits
JWT_EXPIRATION=86400000

# ==========================================
# EMAIL CONFIGURATION (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=markt.ma.noreply@gmail.com
SMTP_PASS=your_gmail_app_password_here
MAIL_FROM=noreply@markt.ma
MAIL_ENABLED=true

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
APP_BASE_URL=https://markt.ma
SERVER_PORT=8080

# ==========================================
# MINIO CONFIGURATION (Object Storage)
# ==========================================
MINIO_ENABLED=true
MINIO_ENDPOINT=https://minio.markt.ma
MINIO_ACCESS_KEY=miniomarkt
MINIO_SECRET_KEY=your_minio_secret_here
MINIO_BUCKET=store-assets
MINIO_REGION=us-east-1
MINIO_SECURE=true

# ==========================================
# CJ DROPSHIPPING API (Phase 2)
# ==========================================
CJ_API_BASE_URL=https://developers.cjdropshipping.com/api2.0/v1
CJ_API_TIMEOUT=30000

# Optional: Master CJ Credentials (für System-Level Operations)
# CJ_MASTER_EMAIL=master@yourcompany.com
# CJ_MASTER_TOKEN=your_master_token_here

# ==========================================
# JAVA OPTIONS (Performance Tuning)
# ==========================================
JAVA_OPTS=-Xms512m -Xmx2048m -XX:+UseG1GC -Dspring.profiles.active=production

# ==========================================
# TELEGRAM AUTH BOT (Phone Verification – KOSTENLOS)
# ==========================================
# Bot erstellen via @BotFather in Telegram → /newbot
# Danach Webhook registrieren: GET https://api.markt.ma/api/auth/telegram-webhook/setup
TELEGRAM_AUTH_BOT_TOKEN=
TELEGRAM_AUTH_BOT_USERNAME=marktma_verify_bot
TELEGRAM_ENABLED=true

# ==========================================
# UNSPLASH API (Freie Bildvorschläge im Create-Store-Wizard)
# ==========================================
# Key anlegen: https://unsplash.com/developers
# Production-Key (5.000 req/h) über Unsplash-Support beantragen.
#
# SICHERHEIT: Dieser Key darf NIEMALS ins Angular-Frontend oder Git gelangen!
# Er wird ausschließlich serverseitig in /etc/storebackend.env gespeichert
# und über Spring @Value("${unsplash.api.key}") im Backend gelesen.
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ==========================================
# DHL PARCEL DE SHIPPING API (Sandbox/Production)
# ==========================================
# Developer Portal: https://developer.dhl.com/
# API: Parcel DE Shipping / DHL Paket DE Versenden V2 (REST, nicht SOAP!)
#
# WICHTIG: Client ID/Secret können bis zu 24h brauchen bis sie aktiv sind.
# Production erfordert echte DHL Geschäftskunden-Zugangsdaten.
#
# SICHERHEIT: DHL_CLIENT_SECRET NIEMALS committen oder loggen!
DHL_ENABLED=false
DHL_ENV=sandbox
DHL_CLIENT_ID=your_dhl_client_id_here
DHL_CLIENT_SECRET=your_dhl_client_secret_here
DHL_AUTH_URL=https://api-sandbox.dhl.com/parcel/de/account/auth/ropc/v1/token
DHL_SHIPPING_BASE_URL=https://api-sandbox.dhl.com/parcel/de/shipping/v2
DHL_SANDBOX_USERNAME=user-valid
DHL_SANDBOX_PASSWORD=SandboxPasswort2023!
DHL_DEFAULT_PROFILE=STANDARD_GRUPPENPROFIL
DHL_DEFAULT_PRODUCT=V01PAK
DHL_DEFAULT_BILLING_NUMBER=33333333330102
DHL_TIMEOUT=30000
DHL_TOKEN_CACHE_DURATION=82800

# Production URLs (DHL_ENV=production):
# DHL_AUTH_URL=https://api-eu.dhl.com/parcel/de/account/auth/ropc/v1/token
# DHL_SHIPPING_BASE_URL=https://api-eu.dhl.com/parcel/de/shipping/v2
# DHL_SANDBOX_USERNAME und DHL_SANDBOX_PASSWORD werden in Production NICHT verwendet!

# ==========================================
# NOTES
# ==========================================
#
# CJ Credentials:
# - Werden PER STORE in der DB gespeichert (supplier_connections table)
# - Reseller verbindet Store über UI: Settings → CJ Connection
# - Keine globalen CJ Credentials nötig (außer für Master-Operations)
#
# Security Checklist:
# ✅ JWT_SECRET ändern (min. 256 Bit)
# ✅ SMTP_PASS ändern (Gmail App Password)
# ✅ MINIO_SECRET_KEY ändern
# ✅ SPRING_DATASOURCE_PASSWORD ändern
# ✅ Datei-Rechte: chmod 600 /etc/storebackend.env
# ✅ Owner: chown storebackend:storebackend /etc/storebackend.env
#
# ==========================================

