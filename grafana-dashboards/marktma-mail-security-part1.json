          "refId": "A",
          "rawSql": "SELECT $__timeGroupAlias(created_at, $__interval), COUNT(*) FILTER (WHERE mail_triggered = TRUE)::double precision AS \"Mail Triggered\", COUNT(*) FILTER (WHERE mail_triggered = TRUE AND blocked = TRUE)::double precision AS \"Mail Blocked\", COUNT(*) FILTER (WHERE mail_sent = TRUE)::double precision AS \"Mail Sent\" FROM security_events WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1;",
